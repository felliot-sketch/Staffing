function goToFacility(id) {
  const f = facilities.find(x => x.id === id);
  if (!f) return;

  document.getElementById('detail-fac-name').textContent = f.name;
  document.getElementById('detail-fac-sub').textContent = `${f.region} · ${f.rdo}`;
  document.getElementById('detail-tier').textContent = tierLabel(f.tier) + ' — Tier ' + tierNum(f.tier);
  document.getElementById('detail-score').textContent = f.score + '/100';
  document.getElementById('detail-vuln').textContent = f.vuln;
  document.getElementById('detail-cons').textContent = f.cons;
  document.getElementById('detail-action').textContent = f.action;
  document.getElementById('d-providers').textContent = f.providers;
  document.getElementById('d-providers-sub').textContent = f.providers === 1 ? '⚠ Single-provider facility' : 'Active this week';
  document.getElementById('d-pto').textContent = f.pto;
  document.getElementById('d-pto-sub').textContent = `${f.shortNotice} short-notice days YTD`;
  document.getElementById('d-fte').textContent = f.fte;
  document.getElementById('d-fte-sub').textContent = 'Budgeted daily FTE';
  document.getElementById('d-prn').textContent = f.prnCount;
  document.getElementById('d-prn-sub').textContent = `${f.prnIn10.length} within 10mi`;

  // Alert
  const alertStrip = document.getElementById('detail-alert-strip');
  if (f.prnIn10.length === 0) {
    alertStrip.style.display = 'flex';
    document.getElementById('detail-alert-text').textContent = 'No PRN providers available within 10mi — immediate outreach required before next absence event.';
  } else {
    alertStrip.style.display = 'none';
  }

  // PTO grid
  const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const ptoGrid = document.getElementById('detail-pto-grid');
  ptoGrid.innerHTML = '';
  f.ptoDays.forEach((count, i) => {
    const cls = count >= 2 ? 'red' : count === 1 ? 'amber' : 'ok';
    const lbl = count >= 2 ? 'Critical' : count === 1 ? 'Absent' : 'Clear';
    ptoGrid.innerHTML += `<div class="pto-day ${cls}">
      <div class="pto-day-name">${days[i]}</div>
      <div class="pto-day-count">${count}</div>
      <div class="pto-day-label">${lbl}</div>
    </div>`;
  });

  // Risk factors
  const rfContainer = document.getElementById('detail-risk-factors');
  const cohortRisk = cohortRiskLabel(f.cohort);
  const tenureRisk = tenureRiskLabel(f.tenure);
  rfContainer.innerHTML = `
    <div style="margin-bottom:10px;">
      <div style="font-size:11px;color:var(--ink-3);margin-bottom:6px;">Cohort (VPS-based · 20% weight)</div>
      <div class="flag-row"><span class="flag-pill cohort-${f.cohort.toLowerCase()}">${f.cohort} — ${cohortDesc(f.cohort)}</span></div>
    </div>
    <div style="margin-bottom:10px;">
      <div style="font-size:11px;color:var(--ink-3);margin-bottom:6px;">Tenure Band (25% weight · short-notice rate)</div>
      <div class="flag-row"><span class="flag-pill ${tenureRisk.cls}">${f.tenure} — ${tenureRisk.rate} short-notice rate</span></div>
    </div>
    <div>
      <div style="font-size:11px;color:var(--ink-3);margin-bottom:6px;">Day-of-Week Risk (15% weight)</div>
      <div class="flag-row">
        <span class="flag-pill dow-mon">Mon — 43.8% short-notice</span>
        <span class="flag-pill dow-fri">Fri — 30.0% short-notice</span>
      </div>
    </div>`;

  // PRN rings
  const prnRings = document.getElementById('detail-prn-rings');
  prnRings.innerHTML = '';
  const rings = [
    { label:'Within 10mi', names: f.prnIn10 },
    { label:'10 – 25mi', names: f.prnIn25 },
    { label:'25 – 50mi', names: f.prnIn50 },
  ];
  rings.forEach(r => {
    const isEmpty = r.names.length === 0;
    const shown = r.names.slice(0,4);
    const more = r.names.length - 4;
    prnRings.innerHTML += `<div class="prn-ring ${isEmpty && r.label === 'Within 10mi' ? 'danger' : ''}">
      <div class="prn-ring-header">
        <div class="prn-ring-label">${r.label}</div>
        <div class="prn-ring-count">${r.names.length} PRN</div>
      </div>
      ${isEmpty ? `<div class="prn-no-coverage"><div class="prn-dot"></div>No PRN available</div>` : 
        `<div class="prn-names">${shown.map(n => `<span class="prn-name">${n.split(',').map(p=>p.trim().charAt(0)+p.trim().slice(1).toLowerCase()).join(', ')}</span>`).join('')}
        ${more > 0 ? `<div class="prn-more">+${more} more</div>` : ''}</div>`}
    </div>`;
  });

  // Pacing
  const pacingContainer = document.getElementById('detail-pacing');
  let pacingHTML = `<div class="pacing-row header">
    <div>Provider</div><div>Q1 Used</div><div>Ann. Pace</div><div>Budget</div><div>Pacing</div><div>Status</div>
  </div>`;
  f.pacing.forEach(p => {
    const pct = Math.min((p.pace / p.budget) * 100, 120);
    const barCls = pct < 65 ? 'green' : pct < 85 ? 'amber' : pct < 110 ? 'orange' : 'red';
    pacingHTML += `<div class="pacing-row">
      <div class="pacing-name ${p.out ? 'out' : ''}">${p.name}</div>
      <div class="pacing-num">${p.used}d</div>
      <div class="pacing-num">${p.pace}d</div>
      <div class="pacing-num">${p.budget}d</div>
      <div><div class="pacing-bar-track"><div class="pacing-bar-fill ${barCls}" style="width:${Math.min(pct,100)}%"></div></div></div>
      <div class="pacing-pct ${barCls}">${Math.round(pct)}%</div>
    </div>`;
  });
  pacingContainer.innerHTML = pacingHTML;

  goTo('facility');
  const bcFac = document.getElementById('bc-fac');
  if (bcFac) bcFac.textContent = f.name.length > 30 ? f.name.slice(0,30) + '…' : f.name;
}

