<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Theoria Medical — Staffing Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;1,9..144,300&family=Roboto+Slab:wght@700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #F2F0EB;
  --surface: #FAFAF8;
  --surface-raised: #FFFFFF;
  --border: #DDD9D0;
  --border-strong: #C4BFB3;
  --ink: #1C1A17;
  --ink-2: #6A6660;
  --ink-3: #9E9A94;
  --red: #B83232;
  --red-bg: #FBF0F0;
  --red-border: #EEC8C8;
  --amber: #C47D0A;
  --amber-bg: #FDF5E6;
  --amber-border: #EDD38A;
  --orange: #B85E0D;
  --orange-bg: #FDF2E8;
  --orange-border: #EDCA9A;
  --green: #1A6640;
  --green-bg: #EBF5EF;
  --green-border: #9ED4B8;
  --blue: #1B4E8A;
  --blue-bg: #EBF1FA;
  --blue-border: #9DBDE8;
  --slate: #3A5066;
  --radius: 8px;
  --radius-sm: 5px;
  --shadow: 0 1px 4px rgba(28,26,23,0.07), 0 0 0 1px rgba(28,26,23,0.05);
  --shadow-md: 0 4px 16px rgba(28,26,23,0.09), 0 0 0 1px rgba(28,26,23,0.06);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'IBM Plex Sans', sans-serif;
  background: var(--bg);
  color: var(--ink);
  font-size: 13px;
  line-height: 1.5;
  min-height: 100vh;
}

/* NAV */
.topnav {
  background: #0D2D6B;
  padding: 0 28px;
  display: flex;
  align-items: center;
  gap: 0;
  height: 48px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-logo {
  font-family: 'Roboto Slab', serif;
  font-size: 16px;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-right: 10px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}
.nav-logo-divider {
  width: 1px;
  height: 14px;
  background: rgba(255,255,255,0.3);
}
.nav-logo-sub {
  font-family: 'IBM Plex Sans', sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  font-style: normal;
}
.nav-logo span { font-style: normal; color: #FFFFFF; }
.nav-badge {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 3px;
  margin-left: 10px;
  letter-spacing: 0.08em;
}
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: rgba(250,250,248,0.5);
  flex: 1;
}
.breadcrumb .crumb {
  cursor: pointer;
  color: rgba(250,250,248,0.6);
  transition: color 0.15s;
}
.breadcrumb .crumb:hover { color: #FAFAF8; }
.breadcrumb .crumb.active { color: #FAFAF8; font-weight: 500; cursor: default; }
.breadcrumb .sep { opacity: 0.3; }
.nav-week {
  font-size: 11px;
  color: rgba(250,250,248,0.45);
  font-family: 'IBM Plex Mono', monospace;
  flex-shrink: 0;
}

/* VIEWS */
.view { display: none; animation: fadeIn 0.2s ease; }
.view.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

.page-wrap { max-width: 1240px; margin: 0 auto; padding: 32px 28px 64px; }

/* SECTION HEADER */
.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24px;
}
.section-title {
  font-family: 'Fraunces', serif;
  font-size: 26px;
  font-weight: 300;
  color: var(--ink);
  line-height: 1.2;
}
.section-subtitle {
  font-size: 12px;
  color: var(--ink-3);
  margin-top: 3px;
}

/* METRIC CARDS */
.metric-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 28px;
}
.metric-card {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px 20px;
  box-shadow: var(--shadow);
}
.metric-label {
  font-size: 11px;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 500;
  margin-bottom: 6px;
}
.metric-value {
  font-size: 32px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1;
}
.metric-value.red { color: var(--red); }
.metric-value.amber { color: var(--amber); }
.metric-value.green { color: var(--green); }
.metric-sub {
  font-size: 11px;
  color: var(--ink-3);
  margin-top: 5px;
}

/* TABS */
.tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 24px;
}
.tab {
  padding: 9px 16px;
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-3);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 0.15s;
}
.tab:hover { color: var(--ink); }
.tab.active { color: var(--ink); border-bottom-color: var(--ink); }

/* POD CARDS */
.pods-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 14px;
}
.pod-card {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  cursor: pointer;
  box-shadow: var(--shadow);
  transition: box-shadow 0.15s, border-color 0.15s;
  position: relative;
  overflow: hidden;
}
.pod-card:hover { box-shadow: var(--shadow-md); border-color: var(--border-strong); }
.pod-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14px;
}
.pod-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
}
.pod-rdo {
  font-size: 11px;
  color: var(--ink-3);
  margin-top: 2px;
}
.risk-badge {
  font-size: 10px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  flex-shrink: 0;
}
.badge-critical { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
.badge-high { background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange-border); }
.badge-elevated { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-border); }
.badge-stable { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
.badge-watch { background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue-border); }

.pod-stats {
  display: flex;
  gap: 20px;
}
.pod-stat { }
.pod-stat-val {
  font-size: 20px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1;
}
.pod-stat-val.red { color: var(--red); }
.pod-stat-val.amber { color: var(--amber); }
.pod-stat-lbl {
  font-size: 10px;
  color: var(--ink-3);
  margin-top: 2px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.pod-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
}
.pod-ci-bar {
  flex: 1;
  margin-right: 14px;
}
.pod-ci-label {
  font-size: 10px;
  color: var(--ink-3);
  margin-bottom: 4px;
  display: flex;
  justify-content: space-between;
}
.pod-ci-track {
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  position: relative;
  overflow: visible;
}
.pod-ci-fill {
  height: 100%;
  border-radius: 2px;
  background: var(--green);
}
.pod-ci-fill.amber { background: var(--amber); }
.pod-ci-fill.red { background: var(--red); }
.pod-arrow {
  font-size: 11px;
  color: var(--ink-3);
  font-weight: 600;
}

/* FACILITY LIST */
.facility-filters {
  display: flex;
  gap: 8px;
  margin-bottom: 18px;
  flex-wrap: wrap;
  align-items: center;
}
.filter-select {
  padding: 7px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface-raised);
  font-family: inherit;
  font-size: 12px;
  color: var(--ink);
  cursor: pointer;
  outline: none;
}
.filter-select:focus { border-color: var(--ink); }
.filter-search {
  padding: 7px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface-raised);
  font-family: inherit;
  font-size: 12px;
  color: var(--ink);
  outline: none;
  flex: 1;
  min-width: 160px;
}
.filter-search:focus { border-color: var(--ink); }
.filter-search::placeholder { color: var(--ink-3); }
.btn-reset {
  padding: 7px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  font-family: inherit;
  font-size: 12px;
  color: var(--ink-2);
  cursor: pointer;
  transition: all 0.15s;
}
.btn-reset:hover { border-color: var(--ink); color: var(--ink); }

/* RISK TABLE */
.risk-table-wrap {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: auto;
}
table {
  width: 100%;
  border-collapse: collapse;
}
thead tr {
  border-bottom: 1px solid var(--border);
}
th {
  padding: 10px 14px;
  font-size: 10px;
  font-weight: 600;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  text-align: left;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
th:hover { color: var(--ink); }
th .sort-icon { margin-left: 3px; opacity: 0.4; }
th.sorted .sort-icon { opacity: 1; }
tbody tr {
  border-bottom: 1px solid var(--bg);
  cursor: pointer;
  transition: background 0.1s;
}
tbody tr:hover { background: var(--bg); }
tbody tr:last-child { border-bottom: none; }
td {
  padding: 11px 14px;
  font-size: 12px;
  color: var(--ink);
  vertical-align: middle;
}
.rank-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--ink-3);
  font-weight: 500;
}
.fac-name { font-weight: 500; }
.fac-rdo { font-size: 11px; color: var(--ink-3); margin-top: 1px; }
.score-bar-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}
.score-bar-track {
  width: 60px;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
  flex-shrink: 0;
}
.score-bar-fill {
  height: 100%;
  border-radius: 2px;
}
.score-bar-fill.critical { background: var(--red); }
.score-bar-fill.high { background: var(--orange); }
.score-bar-fill.elevated { background: var(--amber); }
.score-bar-fill.lowrisk { background: var(--blue); }
.score-bar-fill.stable { background: var(--green); }
.score-val {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  font-weight: 500;
}
.score-val.critical { color: var(--red); }
.score-val.high { color: var(--orange); }
.score-val.elevated { color: var(--amber); }
.score-val.lowrisk { color: var(--blue); }
.score-val.stable { color: var(--green); }
.trend-up { color: var(--red); }
.trend-stable { color: var(--ink-3); }
.trend-down { color: var(--green); }
.driver-tag {
  font-size: 10px;
  background: var(--amber-bg);
  color: var(--amber);
  border: 1px solid var(--amber-border);
  padding: 2px 6px;
  border-radius: 3px;
  white-space: nowrap;
}
.driver-tag.red { background: var(--red-bg); color: var(--red); border-color: var(--red-border); }
.action-text { font-size: 11px; color: var(--ink-2); max-width: 200px; }

/* FACILITY DETAIL */
.detail-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }
.detail-card {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 18px;
  box-shadow: var(--shadow);
}
.detail-card .metric-label { font-size: 10px; margin-bottom: 4px; }
.detail-card .metric-value { font-size: 26px; }

.section-block {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  margin-bottom: 16px;
  box-shadow: var(--shadow);
}
.block-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--ink);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.block-subtitle { font-size: 11px; color: var(--ink-3); font-weight: 400; text-transform: none; letter-spacing: 0; }

/* PTO GRID */
.pto-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
}
.pto-day {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 8px;
  text-align: center;
}
.pto-day.red { background: var(--red-bg); border-color: var(--red-border); }
.pto-day.amber { background: var(--amber-bg); border-color: var(--amber-border); }
.pto-day.ok { background: var(--green-bg); border-color: var(--green-border); }
.pto-day-name {
  font-size: 10px;
  font-weight: 600;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 6px;
}
.pto-day-count {
  font-size: 22px;
  font-weight: 600;
  line-height: 1;
}
.pto-day.red .pto-day-count { color: var(--red); }
.pto-day.amber .pto-day-count { color: var(--amber); }
.pto-day.ok .pto-day-count { color: var(--green); }
.pto-day-label {
  font-size: 10px;
  margin-top: 4px;
}
.pto-day.red .pto-day-label { color: var(--red); }
.pto-day.amber .pto-day-label { color: var(--amber); }
.pto-day.ok .pto-day-label { color: var(--green); }

/* PACING */
.pacing-table { width: 100%; }
.pacing-row {
  display: grid;
  grid-template-columns: 180px 80px 80px 80px 1fr 60px;
  gap: 12px;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--bg);
}
.pacing-row:last-child { border-bottom: none; }
.pacing-row.header { font-size: 10px; font-weight: 600; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.06em; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
.pacing-name { font-size: 12px; font-weight: 500; }
.pacing-name.out::after { content: 'OUT'; font-size: 9px; background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); padding: 1px 4px; border-radius: 3px; margin-left: 6px; font-weight: 600; vertical-align: middle; }
.pacing-num { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--ink-2); }
.pacing-bar-track { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
.pacing-bar-fill { height: 100%; border-radius: 3px; }
.pacing-bar-fill.green { background: var(--green); }
.pacing-bar-fill.amber { background: var(--amber); }
.pacing-bar-fill.orange { background: var(--orange); }
.pacing-bar-fill.red { background: var(--red); }
.pacing-pct { font-size: 11px; font-family: 'IBM Plex Mono', monospace; }
.pacing-pct.green { color: var(--green); }
.pacing-pct.amber { color: var(--amber); }
.pacing-pct.orange { color: var(--orange); }
.pacing-pct.red { color: var(--red); }

/* COHORT + TENURE FLAGS */
.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}
.flag-pill {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 3px;
  letter-spacing: 0.04em;
}
.flag-pill.cohort-c { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
.flag-pill.cohort-b { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-border); }
.flag-pill.cohort-d { background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange-border); }
.flag-pill.cohort-x { background: #F5EBF5; color: #7A3A8A; border: 1px solid #D4ADD4; }
.flag-pill.cohort-a { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
.flag-pill.cohort-aa { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
.flag-pill.tenure-high { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
.flag-pill.tenure-elevated { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-border); }
.flag-pill.tenure-low { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
.flag-pill.dow-mon { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
.flag-pill.dow-fri { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-border); }

/* PRN RINGS */
.prn-rings {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.prn-ring {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
}
.prn-ring.danger { background: var(--red-bg); border-color: var(--red-border); }
.prn-ring-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.prn-ring-label {
  font-size: 10px;
  font-weight: 600;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.prn-ring-count {
  font-size: 10px;
  font-family: 'IBM Plex Mono', monospace;
  color: var(--ink-2);
}
.prn-no-coverage {
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--red);
  font-size: 11px;
  font-weight: 600;
}
.prn-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
.prn-names { }
.prn-name {
  font-size: 11px;
  color: var(--ink-2);
  padding: 2px 0;
  display: block;
}
.prn-more { font-size: 10px; color: var(--ink-3); margin-top: 4px; }

/* RISK SCORE BLOCK */
.risk-score-card {
  background: #0D2D6B;
  color: #FAFAF8;
  border-radius: var(--radius);
  padding: 22px 24px;
  margin-bottom: 16px;
}
.risk-score-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.risk-score-num {
  font-size: 52px;
  font-weight: 600;
  line-height: 1;
}
.risk-score-tier {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.7;
  margin-top: 4px;
}
.risk-score-rec {
  font-size: 12px;
  opacity: 0.75;
  max-width: 260px;
  text-align: right;
  line-height: 1.5;
}
.risk-sub-scores {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.risk-sub {
  background: rgba(255,255,255,0.07);
  border-radius: 6px;
  padding: 12px 14px;
}
.risk-sub-label { font-size: 10px; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 4px; }
.risk-sub-val { font-size: 24px; font-weight: 600; line-height: 1; }
.risk-sub-weight { font-size: 10px; opacity: 0.5; margin-top: 2px; }

/* MATRIX VIEW */
.matrix-container {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  box-shadow: var(--shadow);
}
.matrix-grid {
  display: grid;
  grid-template-columns: 48px 1fr 1fr 1fr;
  grid-template-rows: 1fr 1fr 1fr 40px;
  gap: 0;
  height: 340px;
  margin-top: 12px;
}
.matrix-cell {
  border: 1px solid var(--border);
  padding: 8px;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.matrix-cell.critical-zone { background: #FFF5F5; }
.matrix-cell.urgent-zone { background: #FFF8EE; }
.matrix-cell.watch-zone { background: #FFFBEE; }
.matrix-cell.stable-zone { background: #F5FBF7; }
.matrix-dot {
  display: inline-block;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--red);
  color: white;
  font-size: 9px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
  transition: transform 0.15s;
}
.matrix-dot:hover { transform: scale(1.2); z-index: 10; }
.matrix-dot.critical { background: var(--red); }
.matrix-dot.high { background: var(--orange); }
.matrix-dot.elevated { background: var(--amber); }
.matrix-dot.lowrisk { background: var(--blue); }
.matrix-axis-label {
  font-size: 9px;
  font-weight: 600;
  color: var(--ink-3);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  display: flex;
  align-items: center;
  justify-content: center;
}
.matrix-y-labels {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8px 0;
}
.matrix-y-label {
  font-size: 9px;
  color: var(--ink-3);
  text-align: right;
  padding-right: 8px;
}

/* FACILITY CARDS (pod detail) */
.facility-cards-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}
.facility-card {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 18px;
  cursor: pointer;
  box-shadow: var(--shadow);
  transition: box-shadow 0.15s, border-color 0.15s;
  display: grid;
  grid-template-columns: 1fr auto auto auto auto auto;
  gap: 16px;
  align-items: center;
}
.facility-card:hover { box-shadow: var(--shadow-md); border-color: var(--border-strong); }
.facility-card-name { font-weight: 500; font-size: 13px; }
.facility-card-sub { font-size: 11px; color: var(--ink-3); margin-top: 1px; }
.fac-stat { text-align: center; }
.fac-stat-val { font-size: 16px; font-weight: 600; }
.fac-stat-val.red { color: var(--red); }
.fac-stat-val.amber { color: var(--amber); }
.fac-stat-lbl { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.05em; }

/* ALERT STRIP */
.alert-strip {
  background: var(--red-bg);
  border: 1px solid var(--red-border);
  border-radius: var(--radius-sm);
  padding: 8px 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  font-size: 12px;
  color: var(--red);
  font-weight: 500;
}
.alert-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--red); flex-shrink: 0; }

/* CI STRIP */
.ci-strip {
  background: var(--blue-bg);
  border: 1px solid var(--blue-border);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  font-size: 11px;
}
.ci-strip-label { color: var(--blue); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; font-size: 10px; flex-shrink: 0; }
.ci-strip-val { font-family: 'IBM Plex Mono', monospace; color: var(--blue); font-size: 12px; }
.ci-strip-text { color: var(--ink-2); flex: 1; }

/* RISK FACTORS PANEL */
.risk-factors-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
}
.risk-factor-card {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12px;
  text-align: center;
}
.rf-label { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
.rf-val { font-size: 18px; font-weight: 600; }
.rf-weight { font-size: 10px; color: var(--ink-3); margin-top: 3px; }

/* BACK BTN */
.back-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--ink-3);
  cursor: pointer;
  margin-bottom: 20px;
  transition: color 0.15s;
}
.back-btn:hover { color: var(--ink); }

/* TOOLTIP */
.tooltip {
  position: absolute;
  background: var(--ink);
  color: #FAFAF8;
  font-size: 11px;
  padding: 6px 10px;
  border-radius: 5px;
  white-space: nowrap;
  pointer-events: none;
  z-index: 200;
  display: none;
