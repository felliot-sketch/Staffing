// ── TABS ──
function switchTab(tab) {
  document.querySelectorAll('.tab').forEach((t,i) => {
    t.classList.toggle('active', ['pods','table','matrix'][i] === tab);
  });
  document.getElementById('tab-pods').style.display = tab === 'pods' ? 'grid' : 'none';
  document.getElementById('tab-table').style.display = tab === 'table' ? 'block' : 'none';
  document.getElementById('tab-matrix').style.display = tab === 'matrix' ? 'block' : 'none';
  if (tab === 'table') buildTable(facilities);
}

// ── RISK TABLE ──
function buildTable(data) {
  const tbody = document.getElementById('risk-table-body');
  const sorted = [...data].sort((a,b) => b.score - a.score);
  tbody.innerHTML = sorted.map((f, i) => {
    const tClass = tierClass(f.tier);
    const trendIcon = f.trend === 'up' ? '▲' : f.trend === 'down' ? '▼' : '—';
    const trendClass = f.trend === 'up' ? 'trend-up' : f.trend === 'down' ? 'trend-down' : 'trend-stable';
    const driverCls = f.tier === 'critical' || f.tier === 'high' ? 'red' : '';
    return `<tr onclick="goToFacility('${f.id}')">
      <td><span class="rank-num">#${i+1}</span></td>
      <td><div class="fac-name">${f.name}</div><div class="fac-rdo">${f.rdo}</div></td>
      <td>${f.region}</td>
      <td style="font-size:12px;">${f.rdo}</td>
      <td><div class="score-bar-wrap"><div class="score-bar-track"><div class="score-bar-fill ${tClass}" style="width:${f.vuln}%"></div></div><span class="score-val ${tClass}" style="font-size:11px;">${f.vuln}</span></div></td>
      <td><div class="score-bar-wrap"><div class="score-bar-track"><div class="score-bar-fill ${tClass}" style="width:${f.cons}%"></div></div><span class="score-val ${tClass}" style="font-size:11px;">${f.cons}</span></div></td>
      <td><div class="score-bar-wrap"><div class="score-bar-track"><div class="score-bar-fill ${tClass}" style="width:${f.score}%"></div></div><span class="score-val ${tClass}">${f.score}</span></div></td>
      <td><span class="risk-badge ${tierBadge(f.tier)}" style="font-size:10px;">${tierLabel(f.tier)}</span></td>
      <td><span class="driver-tag ${driverCls}">${f.driver}</span></td>
      <td><div class="action-text">${f.action.split('.')[0]}.</div></td>
      <td><span class="${trendClass}" style="font-weight:600;">${trendIcon}</span></td>
    </tr>`;
  }).join('');
}

function filterTable() {
  const rdo = document.getElementById('filter-rdo').value.toLowerCase();
  const tier = document.getElementById('filter-tier').value;
  const region = document.getElementById('filter-region').value;
  const search = document.getElementById('filter-search').value.toLowerCase();
  const filtered = facilities.filter(f => {
    if (rdo && !f.rdo.toLowerCase().includes(rdo)) return false;
    if (tier && tierLabel(f.tier) !== tier.split(' — ')[1]) return false;
    if (region && f.region !== region) return false;
    if (search && !f.name.toLowerCase().includes(search)) return false;
    return true;
  });
  buildTable(filtered);
}

function resetFilters() {
  ['filter-rdo','filter-tier','filter-region'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('filter-search').value = '';
  buildTable(facilities);
}

let sortDir = {};
function sortTable(col) {
  sortDir[col] = !sortDir[col];
  const tbody = document.getElementById('risk-table-body');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const vals = [0,1,2,3,4,5,6];
  rows.sort((a,b) => {
    const aVal = a.cells[col].innerText.trim();
    const bVal = b.cells[col].innerText.trim();
    const aNum = parseFloat(aVal);
    const bNum = parseFloat(bVal);
    if (!isNaN(aNum) && !isNaN(bNum)) return sortDir[col] ? aNum - bNum : bNum - aNum;
    return sortDir[col] ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
  });
  rows.forEach(r => tbody.appendChild(r));
}

// ── HELPERS ──
function tierClass(t) {
  return { critical:'critical', high:'high', elevated:'elevated', lowrisk:'lowrisk', stable:'stable' }[t] || 'stable';
}
function tierLabel(t) {
  return { critical:'Critical', high:'High Risk', elevated:'Elevated', lowrisk:'Low Risk', stable:'Stable' }[t] || 'Stable';
}
function tierNum(t) {
  return { critical:'1', high:'2', elevated:'3', lowrisk:'4', stable:'5' }[t] || '5';
}
function tierBadge(t) {
  return { critical:'badge-critical', high:'badge-high', elevated:'badge-elevated', lowrisk:'badge-watch', stable:'badge-stable' }[t] || 'badge-stable';
}
function cohortDesc(c) {
  const d = {A:'20+ VPS — Low concern', AA:'15–20 VPS — Low concern', B:'9–14 VPS — Monitor', C:'<9 VPS — High concern, double risk', D:'New hire Feb–Apr — Expected adjustment', X:'Resignation — Departing, flag coverage', Z:'Special — Review with RDO'};
  return d[c] || c;
}
function cohortRiskLabel(c) { return { A:'cohort-a', AA:'cohort-aa', B:'cohort-b', C:'cohort-c', D:'cohort-d', X:'cohort-x', Z:'cohort-a' }[c] || 'cohort-aa'; }
function tenureRiskLabel(t) {
  const m = {
    '<6mo': {cls:'tenure-high', rate:'47.1%'},
    '6–12mo': {cls:'tenure-elevated', rate:'39.6%'},
    '1–2yr': {cls:'tenure-elevated', rate:'35.9%'},
    '2–3yr': {cls:'tenure-elevated', rate:'34.6%'},
    '3+yr': {cls:'tenure-low', rate:'19.0%'},
  };
  return m[t] || {cls:'tenure-elevated', rate:'~35%'};
}

// Matrix hover tooltips
document.querySelectorAll('.matrix-dot').forEach(dot => {
  dot.addEventListener('mouseenter', e => {
    const tooltip = document.getElementById('tooltip');
    tooltip.textContent = dot.title;
    tooltip.style.display = 'block';
    tooltip.style.left = (e.pageX + 10) + 'px';
    tooltip.style.top = (e.pageY - 24) + 'px';
  });
  dot.addEventListener('mouseleave', () => {
    document.getElementById('tooltip').style.display = 'none';
  });
});
