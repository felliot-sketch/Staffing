      <div class="facility-card" onclick="goToFacility('${f.id}')">
        <div>
          <div class="facility-card-name">${f.name} ${noAlert}</div>
          <div class="facility-card-sub">${f.region} · ${f.rdo}</div>
        </div>
        <div class="fac-stat">
          <div class="fac-stat-val">${f.providers}</div>
          <div class="fac-stat-lbl">Providers</div>
        </div>
        <div class="fac-stat">
          <div class="fac-stat-val ${f.pto >= 2 ? 'red' : f.pto === 1 ? 'amber' : ''}">${f.pto}</div>
          <div class="fac-stat-lbl">PTO</div>
        </div>
        <div class="fac-stat">
          <div class="fac-stat-val">${f.prnCount}</div>
          <div class="fac-stat-lbl">PRN ≤50mi</div>
        </div>
        <div>
          <div class="score-bar-wrap">
            <div class="score-bar-track"><div class="score-bar-fill ${tClass}" style="width:${f.score}%"></div></div>
            <span class="score-val ${tClass}">${f.score}</span>
