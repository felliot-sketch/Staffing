// ── NAVIGATION ──
function goTo(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  updateBreadcrumb(view);
}

function updateBreadcrumb(view) {
  const bc = document.getElementById('breadcrumb');
  if (view === 'overview') {
    bc.innerHTML = '<span class="crumb active">Pod Overview</span>';
  } else if (view === 'pod') {
    const pod = POD_DATA[currentPod];
    bc.innerHTML = `<span class="crumb" onclick="goTo('overview')">Pod Overview</span><span class="sep">›</span><span class="crumb active">${pod.name}</span>`;
  } else if (view === 'facility') {
    const pod = POD_DATA[currentPod];
    bc.innerHTML = `<span class="crumb" onclick="goTo('overview')">Pod Overview</span><span class="sep">›</span><span class="crumb" onclick="goTo('pod')">${pod.name}</span><span class="sep">›</span><span class="crumb active" id="bc-fac">Facility</span>`;
  }
}

