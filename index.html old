  const badge = document.getElementById('pod-badge');
  badge.textContent = data.badge;
  badge.className = 'risk-badge ' + data.badgeClass;
  document.getElementById('pod-ci-text').textContent = data.ciText;

  // Build facility cards
  const podFacs = facilities.filter(f => f.pod === pod).sort((a,b) => b.score - a.score);
  const container = document.getElementById('pod-facility-list');
  container.innerHTML = '';
  podFacs.forEach(f => {
    const tClass = tierClass(f.tier);
    const tLabel = tierLabel(f.tier);
    const trendIcon = f.trend === 'up' ? '▲' : f.trend === 'down' ? '▼' : '—';
    const trendClass = f.trend === 'up' ? 'trend-up' : f.trend === 'down' ? 'trend-down' : 'trend-stable';
    const noAlert = f.prnIn10.length === 0 ? '<span style="font-size:10px;background:var(--red-bg);color:var(--red);border:1px solid var(--red-border);padding:2px 6px;border-radius:3px;margin-left:8px;">NO PRN &lt;10mi</span>' : '';
